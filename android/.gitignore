# Create .gitignore
echo "# Flutter/Dart
*.iml
*.lock
*.log
*.pyc
*.swp
.DS_Store
.dart_tool/
.pub/
.build/
packages/
pubspec.lock
build/

# Android
*.iml
*.class
*.log
*.local.properties
.idea/
.gradle/
build/
captures/
gradle_*.html
local.properties

# iOS
*.mode1v3
*.mode2v3
*.moved-aside
*.pbxuser
*.perspectivev3
**/.idea/
**/.sconsign.dblite
**/.vagrant/
**/DerivedData/
**/Pods/
*.xcuserstate
**/.symlinks/
**/profile
**/xcuserdata/
.idea/
.classpath
.project
.settings/

# VS Code
.vscode/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
" > .gitignore

# Add and commit .gitignore
git add .gitignore
git commit -m "Add .gitignore"